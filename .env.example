############################################
# LightRAG - Environment Template
# Copy this file to `.env` and fill values.
############################################

###########################
# Server
###########################
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE=Graph KB Console
WEBUI_DESCRIPTION=Enterprise Knowledge Graph and Retrieval Platform

# INPUT_DIR=/app/inputs
# WORKING_DIR=/app/rag_storage
# LOG_LEVEL=INFO
# VERBOSE=false

###########################
# Auth / Security
###########################
# Required: default login accounts used by /login
# Format: username:password,username2:password2
# Example:
# AUTH_ACCOUNTS=admin:Admin@123456,ops:Ops@123456
# Notes:
# 1) Use comma to separate multiple accounts
# 2) Username and password must not contain comma ","
# 3) Password should be strong and >= 12 chars
AUTH_ACCOUNTS=admin:ChangeMeStrongPassword123!,user:ChangeMeStrongPassword456!

# IMPORTANT: use a long random secret (>= 32 chars recommended)
TOKEN_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32CHARS_MIN
# TOKEN_EXPIRE_HOURS=48
# GUEST_TOKEN_EXPIRE_HOURS=24
# JWT_ALGORITHM=HS256

# Optional API key auth
# LIGHTRAG_API_KEY=CHANGE_ME_API_KEY

###########################
# Runtime behavior
###########################
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true
SUMMARY_LANGUAGE=Chinese
MAX_ASYNC=32
MAX_PARALLEL_INSERT=2

###########################
# LLM (OpenAI-compatible example, e.g. Ark/Volcengine)
###########################
LLM_BINDING=openai
LLM_MODEL=ep-your-llm-model
LLM_BINDING_HOST=https://ark.cn-beijing.volces.com/api/v3
LLM_BINDING_API_KEY=REPLACE_WITH_YOUR_LLM_API_KEY

# Optional: disable model thinking in query/extraction paths where supported
# OPENAI_LLM_EXTRA_BODY={"thinking":{"type":"disabled"}}

###########################
# Embedding (OpenAI-compatible example)
###########################
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=ep-your-embedding-model
EMBEDDING_BINDING_HOST=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_BINDING_API_KEY=REPLACE_WITH_YOUR_EMBEDDING_API_KEY

# Keep this stable after data is created
EMBEDDING_DIM=2048

###########################
# Optional rerank
###########################
RERANK_BINDING=null
# RERANK_MODEL=
# RERANK_BINDING_HOST=
# RERANK_BINDING_API_KEY=

###########################
# Docker Compose build arg (frontend)
###########################
# Usually leave empty for same-origin deployment.
# If frontend and API are on different origins, set full URL:
# VITE_BACKEND_URL=https://your-api-domain
VITE_BACKEND_URL=
